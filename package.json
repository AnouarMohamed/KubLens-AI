{
  "name": "kubernetes-operations-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node scripts/go-task.mjs -C backend run ./cmd/server",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node scripts/go-task.mjs -C backend run ./cmd/server",
    "test:go": "node scripts/go-task.mjs -C backend test ./...",
    "fmt:go": "gofmt -w backend/cmd backend/internal",
    "tidy:go": "node scripts/go-task.mjs -C backend mod tidy",
    "docker:build": "docker build -t kubernetes-operations-dashboard:latest .",
    "docker:run": "docker run --rm -p 3000:3000 kubernetes-operations-dashboard:latest",
    "docker:build:predictor": "docker build -t k8s-ops-predictor:latest ./predictor",
    "docker:run:predictor": "docker run --rm -p 8001:8001 k8s-ops-predictor:latest",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
