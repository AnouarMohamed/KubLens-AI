# Optional: base64-encoded kubeconfig file content.
# If provided, backend calls your real Kubernetes cluster.
# If empty, the app uses built-in mock data.
KUBECONFIG_DATA=""
# Optional multi-cluster contexts (name:base64Kubeconfig pairs separated by commas).
# Example: "prod:<base64>,staging:<base64>"
KUBECONFIG_CONTEXTS=""

# Optional server settings.
PORT="3000"
DIST_DIR="dist"
PREDICTOR_BASE_URL=""
PREDICTOR_TIMEOUT_SECONDS="4"

# Optional assistant provider settings.
# Keep ASSISTANT_PROVIDER="none" to use deterministic local assistant only.
ASSISTANT_PROVIDER="none"
ASSISTANT_TIMEOUT_SECONDS="8"
ASSISTANT_API_BASE_URL="https://api.openai.com/v1"
ASSISTANT_API_KEY=""
ASSISTANT_MODEL=""
ASSISTANT_TEMPERATURE="0.2"
ASSISTANT_MAX_TOKENS="700"

# Optional assistant retrieval grounding (Kubernetes + Docker docs).
# Enabled by default in backend if unset.
ASSISTANT_RAG_ENABLED="true"

# Optional API auth controls.
# When AUTH_ENABLED=true, API requests require a bearer token.
# Format for AUTH_TOKENS: user:role:token,user:role:token
# Example: viewer:viewer:kubelens-viewer,operator:operator:kubelens-operator,admin:admin:kubelens-admin
AUTH_ENABLED="false"
AUTH_TOKENS=""

# Optional rate limiting.
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_REQUESTS="300"
RATE_LIMIT_WINDOW_SECONDS="60"

# Optional terminal hardening.
TERMINAL_ENABLED="true"
TERMINAL_ALLOWED_PREFIXES="kubectl,helm,kustomize,echo,pwd,ls,dir"

# Optional audit persistence.
# If set, backend appends JSONL audit records to this path.
AUDIT_LOG_FILE=""
AUDIT_MAX_ITEMS="500"

# Optional alert integrations.
ALERT_TIMEOUT_SECONDS="5"
ALERTMANAGER_WEBHOOK_URL=""
SLACK_WEBHOOK_URL=""
PAGERDUTY_EVENTS_URL="https://events.pagerduty.com/v2/enqueue"
PAGERDUTY_ROUTING_KEY=""
