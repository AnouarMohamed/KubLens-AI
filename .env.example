# Optional: base64-encoded kubeconfig file content.
# If provided, backend calls your real Kubernetes cluster.
# If empty, the app uses built-in mock data.
KUBECONFIG_DATA=""

# Optional server settings.
PORT="3000"
DIST_DIR="dist"

# Optional assistant provider settings.
# Keep ASSISTANT_PROVIDER="none" to use deterministic local assistant only.
ASSISTANT_PROVIDER="none"
ASSISTANT_TIMEOUT_SECONDS="8"
ASSISTANT_API_BASE_URL="https://api.openai.com/v1"
ASSISTANT_API_KEY=""
ASSISTANT_MODEL=""
ASSISTANT_TEMPERATURE="0.2"
ASSISTANT_MAX_TOKENS="700"
